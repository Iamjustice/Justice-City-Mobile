# Copy this file to `.env` when testing sandbox.
# Use only one active env file at a time.

# ---------------------------------
# Runtime
# ---------------------------------
NODE_ENV=development
PORT=5000

# ---------------------------------
# Supabase (Backend)
# ---------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (Frontend / Browser Auth)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional table overrides
SUPABASE_USERS_TABLE=users
SUPABASE_VERIFICATIONS_TABLE=verifications
SUPABASE_VERIFICATION_DOCUMENTS_TABLE=verification_documents
SUPABASE_VERIFICATION_DOCUMENTS_BUCKET=verification-documents
SUPABASE_FLAGGED_LISTINGS_TABLE=flagged_listings
SUPABASE_FLAGGED_LISTING_COMMENTS_TABLE=flagged_listing_comments
SUPABASE_ADMIN_CHAT_CARDS_TABLE=admin_chat_cards
SUPABASE_REVENUE_RECORDS_TABLE=revenue_records
SUPABASE_LISTINGS_TABLE=listings
SUPABASE_LISTING_IMAGES_TABLE=listing_images
SUPABASE_LISTING_DOCUMENTS_TABLE=listing_documents
SUPABASE_LISTING_VERIFICATION_CASES_TABLE=listing_verification_cases
SUPABASE_LISTING_VERIFICATION_STEPS_TABLE=listing_verification_steps
SUPABASE_LISTING_COMMISSIONS_TABLE=listing_commissions
SUPABASE_COMMISSION_POLICIES_TABLE=commission_policies
SUPABASE_CHAT_CONVERSATIONS_TABLE=chat_conversations
SUPABASE_CHAT_CONVERSATION_MEMBERS_TABLE=chat_conversation_members
SUPABASE_CHAT_MESSAGES_TABLE=chat_messages
SUPABASE_SERVICE_CATALOG_TABLE=service_catalog
SUPABASE_SERVICE_REQUESTS_TABLE=service_request_records
SUPABASE_CONVERSATION_ATTACHMENTS_TABLE=conversation_file_attachments
SUPABASE_CONVERSATION_TRANSCRIPTS_TABLE=conversation_transcripts
SUPABASE_SERVICE_OFFERINGS_TABLE=service_offerings
SUPABASE_HIRING_APPLICATIONS_TABLE=professional_hiring_applications
SUPABASE_HIRING_DOCUMENTS_BUCKET=hiring-documents
SUPABASE_PHONE_OTP_GUARD_TABLE=phone_otp_guards
SUPABASE_EMAIL_OTP_TABLE=verification_email_otps

# ---------------------------------
# Database (Optional for Drizzle workflows)
# ---------------------------------
DATABASE_URL=

# ---------------------------------
# Smile ID (Sandbox)
# ---------------------------------
SMILE_ID_PARTNER_ID=
SMILE_ID_API_KEY=
SMILE_ID_SIGNATURE_API_KEY=
SMILE_ID_BASE_URL=https://testapi.smileidentity.com
SMILE_ID_CALLBACK_URL=https://justicecityltd.com/api/verification/smile-id/callback
SMILE_ID_KYC_PATH=/v1/upload
SMILE_ID_BIOMETRIC_PATH=/v1/upload
SMILE_ID_SOURCE_SDK_VERSION=1.0.0
SMILE_ID_KYC_JOB_TYPE=6
SMILE_ID_BIOMETRIC_JOB_TYPE=1
SMILE_ID_CALLBACK_TIMESTAMP_HEADER=
SMILE_ID_CALLBACK_MAX_SKEW_SEC=900
SMILE_ID_CALLBACK_SECRET=
SMILE_ID_CALLBACK_SIGNATURE_HEADER=x-smile-signature
SMILE_ID_CALLBACK_SIGNATURE_PREFIX=sha256=
VITE_SMILE_LINK_FALLBACK_URL=

# ---------------------------------
# Twilio Verify
# ---------------------------------
# Sandbox/dev flow uses TWILIO_TEST_* when NODE_ENV is not production.
TWILIO_TEST_ACCOUNT_SID=
TWILIO_TEST_AUTH_TOKEN=
TWILIO_TEST_VERIFY_SERVICE_SID=
TWILIO_TEST_VERIFY_BASE_URL=https://verify.twilio.com/v2
TWILIO_TEST_VERIFY_CUSTOM_FRIENDLY_NAME=

# Optional live keys kept blank in sandbox template.
TWILIO_LIVE_ACCOUNT_SID=
TWILIO_LIVE_AUTH_TOKEN=
TWILIO_LIVE_VERIFY_SERVICE_SID=
TWILIO_LIVE_VERIFY_BASE_URL=https://verify.twilio.com/v2
TWILIO_LIVE_VERIFY_CUSTOM_FRIENDLY_NAME=

# Optional backward-compatible fallback keys
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_VERIFY_BASE_URL=https://verify.twilio.com/v2
TWILIO_VERIFY_CUSTOM_FRIENDLY_NAME=
PHONE_OTP_GUARD_SALT=
PHONE_OTP_SEND_COOLDOWN_SEC=60
PHONE_OTP_MAX_SENDS_PER_WINDOW=5
PHONE_OTP_SEND_WINDOW_SEC=3600
PHONE_OTP_MAX_VERIFY_ATTEMPTS=5
PHONE_OTP_VERIFY_BLOCK_SEC=900

# ---------------------------------
# Email OTP (SendGrid)
# ---------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Justice City
SENDGRID_TEMPLATE_ID=
SENDGRID_TEMPLATE_HTML=
SENDGRID_BRAND_NAME=JUSTICE CITY LTD
SENDGRID_TEMPLATE_CODE_KEY=code
SENDGRID_TEMPLATE_EXPIRY_MIN_KEY=expiryMinutes
SENDGRID_TEMPLATE_BRAND_KEY=brandName
EMAIL_OTP_TTL_SEC=600
EMAIL_OTP_KEY_SALT=
EMAIL_OTP_CODE_SALT=

# ---------------------------------
# Transaction Automation Workers
# ---------------------------------
ENABLE_AUTOMATION_WORKERS=true
DIRECT_TIMEOUT_SWEEP_INTERVAL_MS=60000
SERVICE_PDF_SWEEP_INTERVAL_MS=30000
SERVICE_PDF_SWEEP_BATCH_SIZE=5
AUTOMATION_ACTOR_USER_ID=
AUTOMATION_ACTOR_NAME=Justice City Automation
AUTOMATION_ACTOR_ROLE=support

# Service package links / secure forwarding
SERVICE_PROVIDER_LINK_SALT=
SERVICE_PROVIDER_LINK_DEFAULT_EXPIRY_HOURS=72
SERVICE_PROVIDER_PACKAGE_SIGNED_URL_TTL_SEC=3600
PUBLIC_APP_URL=https://justicecityltd.com
